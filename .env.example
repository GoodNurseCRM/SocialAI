# ═══════════════════════════════════════════════════════════════════════════════
# SOCIALAI — Environment Variables Template
# Copy this file to .env for local runs, or paste these keys into Streamlit Cloud
# App settings -> Secrets for the deployed app.
# ═══════════════════════════════════════════════════════════════════════════════

# ── PRIMARY AI (Claude — Required for Onboarding + Ad Plan + Chat) ─────────────
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# ── SECONDARY AI (Gemini — Required for Market Research with Live Search) ───────
GEMINI_API_KEY="your_gemini_api_key_here"

# ── IMAGE GENERATION (Optional) ─────────────────────────────────────────────────
OPENAI_API_KEY="your_openai_api_key_here"       # DALL-E 3
FAL_API_KEY="your_fal_api_key_here"             # FLUX Pro (higher quality, recommended)

# ── BILLING (Optional — only needed for paid subscriptions) ─────────────────────
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# ── FACEBOOK / INSTAGRAM (Meta Graph API) ───────────────────────────────────────
META_ACCESS_TOKEN="your_meta_long_lived_page_access_token"
FB_PAGE_ID="your_facebook_page_id"
IG_ACCOUNT_ID="your_instagram_business_account_id"
META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"

# ── LINKEDIN ──────────────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"

# ── TWITTER / X ───────────────────────────────────────────────────────────────────
X_API_KEY="your_x_api_key"
X_API_SECRET="your_x_api_secret"
X_BEARER_TOKEN="your_x_bearer_token"
X_ACCESS_TOKEN="your_x_access_token"
X_ACCESS_TOKEN_SECRET="your_x_access_token_secret"

# ── TIKTOK ────────────────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY="your_tiktok_client_key"
TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"
TIKTOK_ACCESS_TOKEN="your_tiktok_access_token"

# ── GOOGLE ADS ────────────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN="your_google_ads_developer_token"
GOOGLE_ADS_CLIENT_ID="your_google_oauth_client_id"
GOOGLE_ADS_CLIENT_SECRET="your_google_oauth_client_secret"
GOOGLE_ADS_REFRESH_TOKEN="your_google_ads_refresh_token"
GOOGLE_ADS_CUSTOMER_ID="your_google_ads_customer_id"

# ── GOOGLE SEARCH (for Market Intelligence) ───────────────────────────────────────
GOOGLE_API_KEY="your_google_search_api_key"
GOOGLE_CSE_ID="your_custom_search_engine_id"

# ── TELEGRAM (Good Nurse legacy bot) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="your_telegram_chat_id"

# ── DATABASE ──────────────────────────────────────────────────────────────────────
# Leave blank for local SQLite. Set to Supabase PostgreSQL URI for production.
# Get from: Supabase → Project Settings → Database → URI (use "Session mode" port 5432)
DATABASE_URL=""
# Example: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── APP CONFIG ────────────────────────────────────────────────────────────────────
DB_PATH="./saas_data.db"
APP_SECRET_KEY="change_this_to_a_random_secret_key"

# Public app URL for OAuth/Stripe callbacks.
# Streamlit Cloud normally works without this because the app detects its public URL.
# Set it only if you need an explicit override, e.g. https://your-app.streamlit.app
APP_BASE_URL=""

# ── OWNER / SUPERADMIN ────────────────────────────────────────────────────────────
# Set this to YOUR login email. That account gets the Owner Dashboard tab
# and can view/impersonate all subscribers. Only one owner is supported.
OWNER_EMAIL="your_email@example.com"
ADMIN_EMAIL="your_email@example.com"
